# ─────────────────────────────────────────────
#  JDB Parts — Environment Template
#  Copy this file to .env and fill in values
#  This file IS safe to commit to Git
# ─────────────────────────────────────────────

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=jdb_parts
DB_USER=root
DB_PASS=

# App
APP_ENV=local
APP_DEBUG=true

# PayMongo
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=
PAYMONGO_WEBHOOK_SECRET=

# SMTP / Mailer
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@jdbparts.com
